<ContentForm TContent="ViewModel"
             ContentTabTitle="Streaming info"
             OnSave="OnSave"
             OnCancel="OnCancel"
             Model="Model">
    <ContentInfo Context="streaming">
        <FluentGrid>
            <FluentGridItem xs="12" md="6">
                <FluentSelect TOption="ChannelModel"
                              Label="Twitch channel"
                              Items="availableTwitchChannels"
                              Appearance="Appearance.Filled"
                              Style="width:100%"
                              OptionValue="@(c => c.Url)"
                              OptionText="@(c => $"{c.Name} ({c.Url})")"
                              @bind-Value="streaming.TwitchChannel"/>
                <FluentValidationMessage For="@(() => streaming.TwitchChannel)" />
            </FluentGridItem>
            <FluentGridItem xs="12" md="6">
                <FluentSelect TOption="ChannelModel"
                              Label="YouTube channel"
                              Items="availableYouTubeChannels"
                              Appearance="Appearance.Filled"
                              Style="width:100%"
                              OptionValue="@(c => c.Url)"
                              OptionText="@(c => $"{c.Name} ({c.Url})")"
                              @bind-Value="streaming.YouTubeChannel" />
                <FluentValidationMessage For="@(() => streaming.YouTubeChannel)" />
            </FluentGridItem>
        </FluentGrid>
        <FluentGrid>
            <FluentGridItem xs="12" md="6">
                <FluentTextField Label="Title"
                                 @bind-Value="streaming.Title"
                                 Appearance="FluentInputAppearance.Filled"
                                 Style="width:100%;"
                                 Required="true" />
                <FluentValidationMessage For="@(() => streaming.Title)" />
            </FluentGridItem>
            <FluentGridItem xs="12" md="6">
                <FluentTextField Label="Slug"
                                 @bind-Value="streaming.Slug"
                                 Appearance="FluentInputAppearance.Filled"
                                 Style="width:100%;"
                                 Required="true" />
                <FluentValidationMessage For="@(() => streaming.Slug)" />
            </FluentGridItem>
        </FluentGrid>

        <FluentGrid>
            <FluentGridItem xs="12" md="6">
                <FluentTextField Label="Twitch URL"
                                 @bind-Value="streaming.TwitchUrl"
                                 Appearance="FluentInputAppearance.Filled"
                                 Style="width:100%;"/>
                <FluentValidationMessage For="@(() => streaming.TwitchUrl)" />
            </FluentGridItem>
            <FluentGridItem xs="12" md="6">
                <FluentTextField Label="YouTube URL"
                                 @bind-Value="streaming.YouTubeUrl"
                                 Appearance="FluentInputAppearance.Filled"
                                 Style="width:100%;"/>
                <FluentValidationMessage For="@(() => streaming.YouTubeUrl)" />
            </FluentGridItem>
        </FluentGrid>

        <FluentGrid>
            <FluentGridItem xs="12" md="6">
                <FluentDatePicker Label="Schedule date"
                                  @bind-Value="streaming.ScheduleDate"
                                  Appearance="FluentInputAppearance.Filled"
                                  Style="width:100%;"
                                  Required="true" />
                <FluentValidationMessage For="@(() => streaming.ScheduleDate)" />
            </FluentGridItem>
            <FluentGridItem xs="12" md="3">
                <FluentTimePicker Label="Start time"
                                  @bind-Value="streaming.StartingTime"
                                  Appearance="FluentInputAppearance.Filled"
                                  Style="width:100%;"
                                  Required="true" />
                <FluentValidationMessage For="@(() => streaming.StartingTime)" />
            </FluentGridItem>
            <FluentGridItem xs="12" md="3">
                <FluentTimePicker Label="End time"
                                  @bind-Value="streaming.EndingTime"
                                  Appearance="FluentInputAppearance.Filled"
                                  Style="width:100%;"
                                  Required="true" />
                <FluentValidationMessage For="@(() => streaming.EndingTime)" />
            </FluentGridItem>
        </FluentGrid>

        <FluentGrid>
            <FluentGridItem xs="12" md="12">
                <FluentTextArea Label="Abstract"
                                @bind-Value="streaming.StreamingAbstract"
                                Appearance="FluentInputAppearance.Filled"
                                Rows="10"
                                Style="width:100%;" />
            </FluentGridItem>
        </FluentGrid>
    </ContentInfo>
</ContentForm>
